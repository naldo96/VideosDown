import telebot
import yt_dlp
import re
import os
import logging
from telebot.types import Message

# LOGS para debug VPS
logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)

BOT_TOKEN = "8130330805:AAHebma9WyWokLBFnTGfUj9ECW84roBtN00"
TELEGRAM_CHAT_IDS = [501203904]

bot = telebot.TeleBot(BOT_TOKEN)

def es_chat_autorizado(chat_id):
    return chat_id in TELEGRAM_CHAT_IDS

@bot.message_handler(commands=['start'])
def start(message):
    if not es_chat_autorizado(message.chat.id): return
    bot.reply_to(message, "🟢 VPS Bot TikTok 24/7 ON!")

@bot.message_handler(func=lambda message: True)
def handle_video(message: Message):
    if not es_chat_autorizado(message.chat.id): return
    
    texto = message.text or ""
    tiktok_match = re.search(r'https?://(?:vt|vm|www)?\.?tiktok\.com/[^\s]+|Z[A-Za-z0-9]{5,}', texto, re.IGNORECASE)
    
    if tiktok_match:
        url = tiktok_match.group(0)
        bot.reply_to(message, "⏳ Descargando...")
        try:
            ydl_opts = {
                'format': 'best[height<=1080]',
                'outtmpl': '/tmp/temp.%(ext)s',
                'quiet': True,
            }
            with yt_dlp.YoutubeDL(ydl_opts) as ydl:
                info = ydl.extract_info(url, download=True)
                archivo = '/tmp/temp.mp4' if os.path.exists('/tmp/temp.mp4') else '/tmp/temp.webm'
                
                caption = f"🎥 {info.get('title', '')[:50]}"
                with open(archivo, 'rb') as f:
                    bot.send_video(message.chat.id, f, caption=caption)
                os.remove(archivo)
                bot.reply_to(message, "✅ Listo!")
        except Exception as e:
            logger.error(f"Error: {e}")
            bot.reply_to(message, f"❌ {str(e)[:50]}")

print("🚀 Bot iniciado en VPS")
bot.polling(none_stop=True)
