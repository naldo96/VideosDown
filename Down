set -e
echo "🎬 BOT TIKTOK VPS - INSTALACIÓN AUTOMÁTICA 2026"

# LIMPIEZA
rm -f /root/bot.py /etc/systemd/system/bot*

# PYTHON + PIP
apt update >/dev/null 2>&1
apt install -y python3 python3-pip >/dev/null 2>&1
pip3 install --upgrade pip >/dev/null 2>&1
pip3 install pyTelegramBotAPI yt-dlp --break-system-packages >/dev/null 2>&1

# BOT PRINCIPAL
cat > /root/bot.py << 'BOTCODE'
#!/usr/bin/python3
import telebot, yt_dlp, re, os, sys, logging
logging.basicConfig(level=logging.WARNING)
TOKEN = "8130330805:AAHebma9WyWokLBFnTGfUj9ECW84roBtN00"
CHATID = 501203904
bot = telebot.TeleBot(TOKEN)

@bot.message_handler(commands=['start'])
def cmd_start(msg):
    if msg.chat.id != CHATID: return
    bot.reply_to(msg, "🟢 Bot activo - Envía TikTok")

@bot.message_handler(func=lambda msg: True)
def msg_handler(msg):
    if msg.chat.id != CHATID or not msg.text: return
    txt = msg.text
    # Captura TODOS TikTok
    tk = re.search(r'https?://(?:vt\.|vm\.|www\.)?tiktok\.com/[^\s\u00A0\u202F]+|[A-Za-z0-9]{5,}', txt)
    if tk:
        bot.reply_to(msg, "⏳ Descargando...")
        try:
            opts = {
                'format': 'best[height<=720]',
                'outtmpl': '/tmp/%(id)s.%(ext)s',
                'quiet': True
            }
            with yt_dlp.YoutubeDL(opts) as ytdl:
                info = ytdl.extract_info(tk.group(0), download=True)
            files = [f for f in os.listdir('/tmp') if f.startswith(info['id'])]
            if files:
                vid = '/tmp/' + files[0]
                cap = info.get('title', 'TikTok')[:100]
                with open(vid, 'rb') as vf:
                    bot.send_video(msg.chat.id, vf, caption=cap)
                os.unlink(vid)
                bot.reply_to(msg, "✅ Video listo")
            else:
                bot.reply_to(msg, "❌ Error descarga")
        except Exception as e:
            bot.reply_to(msg, f"⚠️ {str(e)[:60]}")
    else:
        bot.reply_to(msg, "🔗 TikTok link?")

print("Bot started")
bot.polling(none_stop=True)
BOTCODE

chmod +x /root/bot.py

# SYSTEMD
cat > /etc/systemd/system/bot.service << 'SVC'
[Unit]
Description=TikTokBot
After=network.target
[Service]
ExecStart=/usr/bin/python3 /root/bot.py
WorkingDirectory=/root
Restart=always
RestartSec=3
User=root
[Install]
WantedBy=multi-user.target
SVC

# ACTIVAR
systemctl daemon-reload
systemctl enable bot.service
systemctl restart bot.service

