#!/usr/bin/env python3
import telebot
import yt_dlp
import re
import os
import logging
from telebot.types import Message

# CONFIG
BOT_TOKEN = "8130330805:AAHebma9WyWokLBFnTGfUj9ECW84roBtN00"
AUTHORIZED_CHAT = 501203904
logging.basicConfig(format='%(asctime)s - %(levelname)s - %(message)s', level=logging.INFO)

bot = telebot.TeleBot(BOT_TOKEN)

@bot.message_handler(commands=['start', '/start'])
def start_handler(message: Message):
    if message.chat.id != AUTHORIZED_CHAT:
        return
    bot.reply_to(message, 
        "🟢 *Bot TikTok VPS 24/7*\n"
        "🔗 Envía cualquier enlace:\n"
        "• `vt.tiktok.com/...`\n"
        "• `www.tiktok.com/...`\n"
        "• `ZSuaymPRJ`\n\n"
        "💾 Listo para descargar!", 
        parse_mode='Markdown')

@bot.message_handler(func=lambda message: True)
def handle_message(message: Message):
    if message.chat.id != AUTHORIZED_CHAT:
        return
    
    text = message.text or ""
    
    # Regex TikTok COMPLETO
    tiktok_url = re.search(
        r'https?://(?:vt|vm|www)?\.?(?:tiktok\.com)/[^\s]+|Z[A-Za-z0-9]{5,}',
        text, re.IGNORECASE
    )
    
    if tiktok_url:
        url = tiktok_url.group(0)
        bot.reply_to(message, "⏳ *Descargando video...*")
        
        try:
            # YT-DLP optimizado TikTok
            ydl_opts = {
                'format': 'best[height<=1080]/best',
                'outtmpl': '/tmp/%(uploader_id)s.%(ext)s',
                'merge_output_format': 'mp4',
                'user_agent': 'Mozilla/5.0 (iPhone; CPU iPhone OS 16_0 like Mac OS X)',
            }
            
            with yt_dlp.YoutubeDL(ydl_opts) as ydl:
                info = ydl.extract_info(url, download=True)
            
            # Busca archivo MP4
            archivos = [f for f in os.listdir('/tmp') if f.startswith(info.get('uploader_id', ''))]
            if archivos:
                archivo = '/tmp/' + archivos[0]
                caption = f"🎥 *{info.get('title', 'TikTok Video')}*\n"
                caption += f"👤 @{info.get('uploader', 'Usuario')}\n"
                caption += f"⏱️ {info.get('duration', 0)//60}:{info.get('duration', 0)%60:02d}s"
                
                with open(archivo, 'rb') as video_file:
                    bot.send_video(
                        message.chat.id, 
                        video_file, 
                        caption=caption,
                        parse_mode='Markdown'
                    )
                os.remove(archivo)
                bot.reply_to(message, "💾 *¡Video descargado sin watermark!* 📱")
            else:
                bot.reply_to(message, "❌ No se pudo procesar el video")
                
        except Exception as e:
            logging.error(f"Error descargando {url}: {e}")
            bot.reply_to(message, f"⚠️ *Error técnico*\n```{str(e)[:100]}```", parse_mode='Markdown')
    else:
        bot.reply_to(message, "🔗 *Envía enlace de TikTok*\n\n`vt.tiktok.com/ABC123` funciona perfecto", parse_mode='Markdown')

if __name__ == '__main__':
    print("🚀 Bot TikTok iniciado en VPS Hostinger")
    print("👤 Chat autorizado:", AUTHORIZED_CHAT)
    bot.polling(none_stop=True)
EOF

